voice.activi.io {
    # Vonage answer URL — returns NCCO, standard HTTP
    handle /vonage/answer {
        reverse_proxy orchestrator:3000
    }

    # Vonage event URL — call lifecycle events, standard HTTP
    handle /vonage/events {
        reverse_proxy orchestrator:3000
    }

    # Vonage media streaming — long-lived WebSocket, disable buffering
    handle /vonage/media {
        reverse_proxy orchestrator:3000 {
            flush_interval -1
            transport http {
                read_timeout  300s
                write_timeout 300s
            }
        }
    }

    # API endpoints (outbound calls, batch)
    handle /api/calls/* {
        reverse_proxy orchestrator:3000
    }

    # Telnyx webhook + media (for when Telnyx is active)
    handle /telnyx/* {
        reverse_proxy orchestrator:3000
    }

    # Health check
    handle /health {
        reverse_proxy orchestrator:3000
    }

    # Metrics — internal Prometheus only (external blocked)
    handle /metrics {
        respond 403
    }

    # Management API — all /api/manage/* routes
    # Strip the /api/manage prefix so management-api receives clean paths
    handle /api/manage/* {
        uri strip_prefix /api/manage
        reverse_proxy management-api:3001
    }

    # RAG System API — all /api/rag/* routes
    # Strip the /api/rag prefix so rag-system receives clean paths
    handle /api/rag/* {
        uri strip_prefix /api/rag
        reverse_proxy rag-system:8000
    }

    # RAG TEST (exact match)
    handle /api/rag-test {
        reverse_proxy rag-system:8000
    }

    # Management UI — React app (placeholder until UI service is built)
    handle /app* {
        reverse_proxy management-api:3001
    }

    # Grafana dashboard
    handle /grafana* {
        reverse_proxy grafana:3000
    }

    # Catch-all — reject unknown paths
    handle {
        respond 404
    }

    # Structured access logging with rotation
    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

n8n.activi.io {
    reverse_proxy 172.18.0.9:5678
    
    log {
        output file /var/log/caddy/n8n-access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}
