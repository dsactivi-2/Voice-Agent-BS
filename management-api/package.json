    "@fastify/rate-limit": "^10.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.3.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/jsonwebtoken": "^9.0.0",
