{
  "name": "voice-system-orchestrator",
  "version": "0.1.0",
  "description": "Voice AI System Orchestrator for BS/SR sales calls",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:down": "node-pg-migrate down"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.27.0",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@fastify/websocket": "^11.2.0",
    "@vonage/server-sdk": "^3.26.4",
    "@vonage/voice": "1.20.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.3",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.25.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "telnyx": "^5.40.0",
    "zod": "^4.3.6",
    "@fastify/rate-limit": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.1",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}