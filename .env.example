# =============================================================
# Voice System — Environment Variable Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# Telnyx — telephony provider
# -------------------------------------------------------------
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_APP_ID=
TELNYX_PHONE_BS=
TELNYX_PHONE_SR=

# -------------------------------------------------------------
# Deepgram — speech-to-text
# -------------------------------------------------------------
DEEPGRAM_API_KEY=

# -------------------------------------------------------------
# OpenAI — LLM inference
# -------------------------------------------------------------
OPENAI_API_KEY=

# -------------------------------------------------------------
# Azure Cognitive Services — text-to-speech
# -------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_REGION=westeurope

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=voice_system
POSTGRES_USER=voice_app
POSTGRES_PASSWORD=

# Full connection URL used by the application (matches the values above)
DATABASE_URL=postgresql://voice_app:PASSWORD@postgres:5432/voice_system

# -------------------------------------------------------------
# Application
# -------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# -------------------------------------------------------------
# LLM configuration
# -------------------------------------------------------------
LLM_MINI_MODEL=gpt-4o-mini
LLM_FULL_MODEL=gpt-4o
LLM_TIMEOUT_MS=5000

# Thresholds that trigger promotion from mini to full LLM
LLM_SWITCH_INTEREST_THRESHOLD=0.72
LLM_SWITCH_COMPLEXITY_THRESHOLD=0.60

# -------------------------------------------------------------
# Voice Activity Detection (VAD)
# -------------------------------------------------------------
VAD_ENDPOINTING_MS=300
VAD_GRACE_MS=200
VAD_BARGE_IN_MIN_MS=150
VAD_SILENCE_TIMEOUT_MS=10000

# -------------------------------------------------------------
# Text-to-Speech (TTS)
# -------------------------------------------------------------
TTS_VOICE_BS=bs-BA-GoranNeural
TTS_VOICE_SR=sr-RS-NicholasNeural
TTS_FORMAT=raw-16khz-16bit-mono-pcm
TTS_CACHE_TTL_SECONDS=86400

# -------------------------------------------------------------
# Adaptive delay / conversation pacing
# -------------------------------------------------------------
ADAPTIVE_DELAY_MIN_MS=200
ADAPTIVE_DELAY_MAX_MS=800
SILENCE_PRESSURE_AFTER_OFFER_MS=2500

# -------------------------------------------------------------
# Conversation memory
# -------------------------------------------------------------
MEMORY_SUMMARY_INTERVAL_TURNS=5
MEMORY_ACTIVE_WINDOW_TURNS=4
MEMORY_CROSS_CALL_ENABLED=true

# -------------------------------------------------------------
# Anti-loop / spam protection
# -------------------------------------------------------------
ANTI_LOOP_COOLDOWN_HOURS=24

# -------------------------------------------------------------
# Audio ring buffer
# -------------------------------------------------------------
RING_BUFFER_SIZE_KB=32
RING_BUFFER_CHANNELS=50

# -------------------------------------------------------------
# A/B testing
# -------------------------------------------------------------
AB_TEST_ENABLED=false
AB_TEST_GROUPS=mini_only,mini_to_full,full_only
